# ==========================================
# Development environment
# ==========================================

# MySQL
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=smart_money_tracking
MYSQL_USER=smartuser
MYSQL_PASSWORD=smartpass

# Backend
DB_URL=jdbc:mysql://db:3306/smart_money_tracking?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=smartuser
DB_PASSWORD=smartpass
JWT_SECRET=dev_secret_replace_with_secure_value_32_chars_min
NLP_SERVICE_URL=http://ai-service:8000

# AI Service
GROQ_API_KEY=
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TIMEOUT_SEC=15
ENABLE_LLM_REPAIR=true
LLM_CONFIDENCE_THRESHOLD=0.65
PHOBERT_MODEL_PATH=/app/models/phobert-finance-ner-final

# Mobile
EXPO_PUBLIC_API_URL=http://host.docker.internal:8080/api/v1
