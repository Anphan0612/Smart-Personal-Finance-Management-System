# ==========================================
# Production environment template
# Copy to .env.production and fill real secrets
# ==========================================

# MySQL
MYSQL_ROOT_PASSWORD=__REQUIRED__
MYSQL_DATABASE=smart_money_tracking
MYSQL_USER=smartuser
MYSQL_PASSWORD=__REQUIRED__

# Backend
DB_URL=jdbc:mysql://db:3306/smart_money_tracking?useSSL=true&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=smartuser
DB_PASSWORD=__REQUIRED__
JWT_SECRET=__REQUIRED_32_BYTES_MIN__
NLP_SERVICE_URL=http://ai-service:8000

# AI Service
GROQ_API_KEY=__OPTIONAL_IF_DISABLED__
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TIMEOUT_SEC=15
ENABLE_LLM_REPAIR=true
LLM_CONFIDENCE_THRESHOLD=0.65
PHOBERT_MODEL_PATH=/app/models/phobert-finance-ner-final

# Mobile
EXPO_PUBLIC_API_URL=https://api.example.com/api/v1
