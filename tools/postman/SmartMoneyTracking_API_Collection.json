{
  "info": {
    "name": "Smart Money Tracking API",
    "description": "Postman collection for Smart Personal Finance Management System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/register",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "register"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"email\": \"testuser@example.com\",\n  \"password\": \"password123\",\n  \"phone\": \"0123456789\",\n  \"cccd\": \"012345678912\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.token) {",
                  "    pm.environment.set(\"authToken\", jsonData.token);",
                  "}",
                  "if (jsonData.accessToken) {",
                  "    pm.environment.set(\"authToken\", jsonData.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser\",\n  \"password\": \"password123\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Wallets",
      "item": [
        {
          "name": "Create Wallet",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.payload && jsonData.payload.id) {",
                  "    pm.environment.set(\"walletId\", jsonData.payload.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/wallets",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "wallets"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Main Wallet\",\n  \"balance\": 1000.00,\n  \"currencyCode\": \"VND\",\n  \"type\": \"CASH\"\n}"
            }
          }
        },
        {
          "name": "Get Wallets",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/wallets",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "wallets"]
            }
          }
        },
        {
          "name": "Get Wallet by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/wallets/{{walletId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "wallets", "{{walletId}}"]
            }
          }
        },
        {
          "name": "Update Wallet",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/wallets/{{walletId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "wallets", "{{walletId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Wallet\",\n  \"balance\": 1500.00,\n  \"currencyCode\": \"VND\",\n  \"type\": \"BANK\"\n}"
            }
          }
        },
        {
          "name": "Delete Wallet",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/wallets/{{walletId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "wallets", "{{walletId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.payload && jsonData.payload.id) {",
                  "    pm.environment.set(\"transactionId\", jsonData.payload.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "transactions"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"walletId\": \"{{walletId}}\",\n  \"categoryId\": \"1\",\n  \"amount\": 500.00,\n  \"description\": \"Grocery shopping\",\n  \"type\": \"EXPENSE\",\n  \"transactionDate\": \"2026-03-24T12:00:00\"\n}"
            }
          }
        },
        {
          "name": "Get Transactions by Wallet ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions?walletId={{walletId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "transactions"],
              "query": [{ "key": "walletId", "value": "{{walletId}}" }]
            }
          }
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "transactions", "{{transactionId}}"]
            }
          }
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "transactions", "{{transactionId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"walletId\": \"{{walletId}}\",\n  \"categoryId\": \"2\",\n  \"amount\": 600.00,\n  \"description\": \"Updated grocery shopping\",\n  \"type\": \"EXPENSE\",\n  \"transactionDate\": \"2026-03-24T14:30:00\"\n}"
            }
          }
        },
        {
          "name": "Delete Transaction",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/transactions/{{transactionId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "transactions", "{{transactionId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Bank Accounts",
      "item": [
        {
          "name": "Create Bank Account",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "if (jsonData.success && jsonData.payload && jsonData.payload.id) {",
                  "    pm.environment.set(\"bankAccountId\", jsonData.payload.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/bank-accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "bank-accounts"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountNumber\": \"1234567890\",\n  \"bankName\": \"TPBank\",\n  \"balance\": 5000.00,\n  \"currencyCode\": \"VND\",\n  \"type\": \"SAVINGS\"\n}"
            }
          }
        },
        {
          "name": "Get Bank Accounts",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/bank-accounts",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "bank-accounts"]
            }
          }
        },
        {
          "name": "Get Bank Account by ID",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/bank-accounts/{{bankAccountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "bank-accounts", "{{bankAccountId}}"]
            }
          }
        },
        {
          "name": "Update Bank Account",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Authorization", "value": "Bearer {{authToken}}" },
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/v1/bank-accounts/{{bankAccountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "bank-accounts", "{{bankAccountId}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"accountNumber\": \"0987654321\",\n  \"bankName\": \"Vietcombank\",\n  \"balance\": 7000.00,\n  \"currencyCode\": \"VND\",\n  \"type\": \"CHECKING\"\n}"
            }
          }
        },
        {
          "name": "Delete Bank Account",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{authToken}}" }],
            "url": {
              "raw": "{{baseUrl}}/api/v1/bank-accounts/{{bankAccountId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "bank-accounts", "{{bankAccountId}}"]
            }
          }
        }
      ]
    }
  ]
}
