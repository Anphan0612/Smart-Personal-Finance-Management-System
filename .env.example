# --- Database Settings ---
DB_PORT=3307
MYSQL_DATABASE=smart_money_tracking
MYSQL_USER=smartuser
MYSQL_PASSWORD=smartpass
MYSQL_ROOT_PASSWORD=rootpass

# --- Backend Settings ---
BACKEND_PORT=8080
BACKEND_DEBUG_PORT=5005
SPRING_PROFILES_ACTIVE=dev
JWT_SECRET=replace-with-a-strong-secret-at-least-32-bytes-long

# --- AI Service Settings ---
AI_PORT=8000
AI_DEBUG_PORT=5678
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=openai/gpt-oss-120b
PHOBERT_MODEL_PATH=/app/ml-models/phobert-finance-ner-final

# --- Tunneling Settings ---
CLOUDFLARE_TUNNEL_TOKEN=your_cloudflare_tunnel_token_here

# --- Mobile Settings ---
# This is usually auto-updated by scripts/dev-setup.js
EXPO_PUBLIC_API_URL=http://localhost:8080/api/v1
