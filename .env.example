# ==========================================
# ☕ Backend (Spring Boot)
# ==========================================
DB_URL=jdbc:mysql://localhost:3306/smart_money_tracking?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=your_db_password_here
JWT_SECRET=your_jwt_secret_key_must_be_at_least_256_bits_long

# ==========================================
# 🐍 AI Service (Python / Groq)
# ==========================================
GROQ_API_KEY=your_api_key_here
GROQ_MODEL=openai/gpt-oss-120b
GROQ_TIMEOUT_SEC=15

# Enable Groq LLM "repair" when confidence is low
ENABLE_LLM_REPAIR=true
LLM_CONFIDENCE_THRESHOLD=0.65
